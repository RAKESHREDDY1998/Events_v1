@model Event
@{
    string title = ViewBag.Action + " Event";
}
<h2>@title</h2>
<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="row mb-3">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control">
    </div>
    <div class="row mb-3">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control">
    </div>
    <div class="row mb-3">
        <label asp-for="TicketPrice">Ticket price</label>
        <input asp-for="TicketPrice" class="form-control">
    </div>

    <div class="form-group">
        <label> Category</label>
        <select asp-for="CategoryId" class="form-control">
            @foreach (Category cat in ViewBag.Categories)
            {
                <option value=@cat.CategoryId>@cat.Name</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="EventId" />
    <button type="submit" class="btn btn-primary">Submit</button>
    <a asp-controller="Admin" asp-action="List" class="btn btn-primary">Cancel</a>
</form>