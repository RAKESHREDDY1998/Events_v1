@model List<Event>

@{
    ViewData["Title"] = "List all events";
}
<form>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Event title</th>
                <th>Description</th>
                <th>Ticket price</th>
                <th>Category</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model)
            {
                    <tr>
                        <td>@ev.Title</td>
                        <td>@ev.Description</td>
                        <td>@ev.TicketPrice.ToString("C2")</td>
                        <td>@ev.Category.Name</td>
                        <td>
                            <a asp-controller="Admin" asp-action="Edit" asp-route-id="@ev.EventId">Edit</a>
                            <a asp-controller="Admin" asp-action="Delete" asp-route-id="@ev.EventId">Delete</a>
                        </td>
                        <td>
                            <a asp-controller="Admin" asp-action="EventSales" asp-route-id="@ev.EventId">View Sales</a>
                        </td>
                    </tr>
            }
        </tbody>
    </table>
    <button asp-controller="Admin" asp-action="Add" class="btn btn-success">Add new event</button>

</form>