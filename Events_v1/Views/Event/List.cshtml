@model List<Event>

@{
    ViewData["Title"] = "List all events";
}
<form>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Event title</th>
                <th>Description</th>
                <th>Ticket price</th>
                <th>Category</th>
                <th> </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model)
            {
                    <tr>
                        <td>@ev.Title</td>
                        <td>@ev.Description </td>
                        <td>@ev.TicketPrice.ToString("C2")</td>
                        <td>@ev.Category.Name </td>
                        <td>
                            <button type="submit" name="id" asp-action="Buy" asp-controller="Cart" asp-route-id="@ev.EventId" class="btn btn-primary"> Buy Tickets</button>
                        </td>
                    </tr>
            }
        </tbody>
    </table>
</form>